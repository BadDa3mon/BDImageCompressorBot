[Unit]
Description=BDImageCompressorBot Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=head
Group=head
WorkingDirectory=/opt/Bots/BDImageCompressorBot
EnvironmentFile=/opt/Bots/BDImageCompressorBot/.env
ExecStart=/opt/Bots/BDImageCompressorBot/.venv/bin/python /opt/Bots/BDImageCompressorBot/bot.py
Restart=always
RestartSec=3

NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
