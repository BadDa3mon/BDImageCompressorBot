BOT_TOKEN=123456:ABCDEF_your_token_here
# Telegram API credentials for local Bot API server (https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Для локального Bot API (пример: http://127.0.0.1:8081)
LOCAL_BOT_API_URL=

# JPEG settings
JPEG_QUALITY=80          # 1..95 (обычно 75-85 оптимально)
JPEG_PROGRESSIVE=1       # 1/0
JPEG_OPTIMIZE=1          # 1/0

# PNG settings
PNG_OPTIMIZE=1           # 1/0
PNG_COMPRESS_LEVEL=9     # 0..9
PNG_TO_JPEG=1            # 1/0 (конвертировать PNG в JPEG для сильного сжатия)
PNG_JPEG_BG=white        # white|black (фон при прозрачности PNG)

# Optional resize (по длинной стороне). 0 = не ресайзить
MAX_SIZE=0               # например 1920

# Если включить, PNG без альфы может квантизироваться (с потерями, но часто сильно уменьшает вес)
PNG_QUANTIZE=0           # 1/0

# Лимит на количество файлов изображений внутри ZIP (защита от слишком больших архивов)
ZIP_IMAGE_LIMIT=2000

# Лимит на общее количество файлов в ZIP
ZIP_FILE_LIMIT=10000

# Максимальный суммарный размер распаковки ZIP (MB)
ZIP_MAX_EXTRACT_MB=512

# Лимит размера входящего файла (MB) для одной картинки или ZIP
MAX_INPUT_FILE_MB=100

# Ограничение Bot API на скачивание файлов ботом.
# Для облачного API обычно ~20MB, для локального можно ставить больше (например 2000).
TELEGRAM_DOWNLOAD_LIMIT_MB=20

# Таймауты запросов к Bot API (сек)
BOT_API_REQUEST_TIMEOUT_SEC=900
BOT_API_DOWNLOAD_TIMEOUT_SEC=1800
BOT_API_GET_FILE_RETRIES=3
BOT_API_SERVER_FILES_DIR=/var/lib/telegram-bot-api
BOT_API_LOCAL_FILES_DIR=/opt/Bots/BDImageCompressorBot/data

# Логи бота в папку проекта
LOG_DIR=logs

# Папка хранения артефактов задач: artifacts/<job_id>/{input,output,meta}
STORAGE_DIR=artifacts
